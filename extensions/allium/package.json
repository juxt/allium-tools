{
  "name": "allium-vscode",
  "displayName": "Allium Tools for VS Code",
  "description": "Allium language support for VS Code: diagnostics, refactors, hover, definitions, formatting, and more.",
  "version": "3.0.5",
  "license": "MIT",
  "publisher": "juxt",
  "repository": {
    "type": "git",
    "url": "https://github.com/juxt/allium-tools.git"
  },
  "bugs": {
    "url": "https://github.com/juxt/allium-tools/issues"
  },
  "keywords": [
    "allium",
    "specification",
    "formal methods",
    "lsp",
    "language server"
  ],
  "icon": "icon.png",
  "files": [
    "dist/extension.js",
    "dist/allium-lsp.js",
    "dist/allium_wasm.js",
    "dist/allium_wasm_bg.wasm",
    "language-basics/**",
    "README.md",
    "LICENSE",
    "package.json",
    "icon.png"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "bin": {
    "allium-check": "./dist/src/check.js",
    "allium-format": "./dist/src/format.js",
    "allium-diagram": "./dist/src/diagram.js",
    "allium-trace": "./dist/src/trace.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "allium",
        "aliases": [
          "Allium",
          "allium"
        ],
        "extensions": [
          ".allium"
        ],
        "configuration": "./language-basics/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "allium",
        "scopeName": "source.allium",
        "path": "./language-basics/syntaxes/allium.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "allium",
        "path": "./language-basics/snippets/allium.code-snippets"
      }
    ],
    "configuration": {
      "title": "Allium",
      "properties": {
        "allium.diagnostics.mode": {
          "type": "string",
          "enum": [
            "strict",
            "relaxed"
          ],
          "default": "strict",
          "markdownDescription": "Controls diagnostics strictness. `strict` enables all checks. `relaxed` suppresses temporal-guard warnings and downgrades some diagnostics."
        },
        "allium.profile": {
          "type": "string",
          "enum": [
            "custom",
            "strict-authoring",
            "legacy-migration",
            "doc-writing"
          ],
          "default": "custom",
          "markdownDescription": "Preset profile for diagnostics behavior. `custom` uses `allium.diagnostics.mode`; `strict-authoring` forces strict diagnostics; `legacy-migration` and `doc-writing` force relaxed diagnostics."
        },
        "allium.format.indentWidth": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "markdownDescription": "Indent width used by Allium document formatting."
        },
        "allium.format.topLevelSpacing": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 3,
          "markdownDescription": "Blank lines inserted between top-level Allium blocks during formatting."
        }
      }
    },
    "commands": [
      {
        "command": "allium.runChecks",
        "title": "Allium: Run Checks"
      },
      {
        "command": "allium.applySafeFixes",
        "title": "Allium: Apply All Safe Fixes"
      },
      {
        "command": "allium.applySafeFixes.missingEnsures",
        "title": "Allium: Apply Safe Fixes (Missing Ensures)"
      },
      {
        "command": "allium.applySafeFixes.temporalGuards",
        "title": "Allium: Apply Safe Fixes (Temporal Guards)"
      },
      {
        "command": "allium.showSpecHealth",
        "title": "Allium: Show Spec Health"
      },
      {
        "command": "allium.showProblemsSummary",
        "title": "Allium: Show Problems Summary"
      },
      {
        "command": "allium.previewRename",
        "title": "Allium: Preview Rename Plan"
      },
      {
        "command": "allium.previewRuleSimulation",
        "title": "Allium: Preview Rule Simulation"
      },
      {
        "command": "allium.generateRuleTestScaffold",
        "title": "Allium: Generate Rule Test Scaffold"
      },
      {
        "command": "allium.applyQuickFixesInFile",
        "title": "Allium: Apply All Quick Fixes In File"
      },
      {
        "command": "allium.cleanStaleSuppressions",
        "title": "Allium: Clean Stale Suppressions"
      },
      {
        "command": "allium.openRelatedSpecOrTest",
        "title": "Allium: Open Related Spec/Test"
      },
      {
        "command": "allium.explainFinding",
        "title": "Allium: Explain Finding At Cursor"
      },
      {
        "command": "allium.checkSpecDrift",
        "title": "Allium: Check Spec Drift"
      },
      {
        "command": "allium.manageBaseline",
        "title": "Allium: Manage Baseline"
      },
      {
        "command": "allium.explainFindingDiagnostic",
        "title": "Allium: Explain Finding"
      },
      {
        "command": "allium.createImportedSymbolStub",
        "title": "Allium: Create Imported Symbol Stub"
      },
      {
        "command": "allium.generateDiagram",
        "title": "Allium: Generate Diagram"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --external:allium-parser-wasm --outfile=dist/extension.js",
    "bundle-lsp": "node -e \"const {existsSync,mkdirSync,copyFileSync}=require('fs');const src='../../packages/allium-lsp/dist/bin.js';if(existsSync(src)){mkdirSync('dist',{recursive:true});copyFileSync(src,'dist/allium-lsp.js');console.log('Bundled allium-lsp into dist/allium-lsp.js');}else{console.warn('allium-lsp not yet built, skipping. Run: npm run build -w packages/allium-lsp');}\"",
    "bundle-wasm": "node -e \"const {mkdirSync,copyFileSync}=require('fs');const p='../../packages/allium-parser-wasm';mkdirSync('dist',{recursive:true});copyFileSync(p+'/allium_wasm.js','dist/allium_wasm.js');copyFileSync(p+'/allium_wasm_bg.wasm','dist/allium_wasm_bg.wasm');console.log('Bundled allium-parser-wasm into dist/')\"",
    "build:release": "npm run build && npm run bundle && npm run bundle-lsp && npm run bundle-wasm",
    "test": "npm run build && node ../../scripts/run-node-tests.mjs ./dist/test",
    "lint": "tsc -p ./tsconfig.json --noEmit",
    "check": "npm run build && node ./dist/src/check.js",
    "format:allium": "npm run build && node ./dist/src/format.js",
    "diagram:allium": "npm run build && node ./dist/src/diagram.js",
    "trace:allium": "npm run build && node ./dist/src/trace.js"
  },
  "dependencies": {
    "allium-parser-wasm": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.3"
  }
}
