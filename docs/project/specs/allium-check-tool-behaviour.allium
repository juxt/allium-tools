-- allium: 1
-- allium-check-tool-behaviour.allium
-- Scope: Standalone CLI behavior for running Allium checks outside VS Code.
-- Includes:
--   - CLI argument parsing and mode selection
--   - Input resolution for files, directories, and wildcard patterns
--   - Finding output format and exit code behavior
-- Excludes:
--   - VS Code editor integration and code actions
--   - Packaging/distribution details for npm or extension marketplaces

value CheckMode {
    value: strict | relaxed
}

value CheckInput {
    value: file_path | directory_path | wildcard_pattern
}

entity CheckedFile {
    path: String
}

entity CheckRun {
    mode: CheckMode
    inputs: Set<CheckInput>
    files: Set<CheckedFile>
}

rule InvalidModeIsRejected {
    when: CheckCommandInvoked(mode)
    requires: mode not in [strict, relaxed]

    ensures: UsagePrinted()
    ensures: ProcessExit(code: 2)
}

rule MissingInputsAreRejected {
    when: CheckCommandInvokedWithoutInputs()

    ensures: UsagePrinted()
    ensures: ProcessExit(code: 2)
}

rule MissingResolvedFilesAreRejected {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: ResolveAlliumFiles(inputs).is_empty = true

    ensures: UserInformed(message: "No .allium files found for the provided inputs.")
    ensures: ProcessExit(code: 2)
}

rule DirectoryInputExpandsToAlliumFiles {
    when: CheckCommandInvokedWithInput(input)
    requires: input.kind = directory_path

    ensures: CheckRun.files includes input.recursive_files where file.extension = ".allium"
}

rule WildcardInputMatchesAlliumFiles {
    when: CheckCommandInvokedWithInput(input)
    requires: input.kind = wildcard_pattern

    ensures: CheckRun.files includes file where MatchesWildcard(file.relative_path, input)
    ensures: CheckRun.files excludes file where file.extension != ".allium"
}

rule FindingsArePrintedPerFile {
    when: FileChecked(file)
    requires: file.findings.count > 0

    ensures: LinePrinted(format: "<path>:<line>:<character> <severity> <code> <message>")
}

rule NonInfoFindingsFailTheRun {
    when: CheckRunCompleted(run)
    requires: run.findings.any(f => f.severity in [error, warning])

    ensures: ProcessExit(code: 1)
}

rule InformationalOnlyFindingsSucceed {
    when: CheckRunCompleted(run)
    requires: run.findings.all(f => f.severity = info)

    ensures: LinePrinted(message: "No blocking findings.")
    ensures: ProcessExit(code: 0)
}

rule AutofixFlagAppliesSafeFixes {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: command_args includes "--autofix"

    ensures: SafeFixApplied(kind: missing_ensures_scaffold)
    ensures: SafeFixApplied(kind: missing_when_scaffold)
    ensures: SafeFixApplied(kind: temporal_guard_scaffold)
}

rule FixCodeOptionScopesAutofixToSelectedDiagnosticCodes {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--autofix"
    requires: options includes "--fix-code allium.rule.missingEnsures"

    ensures: SafeFixApplied(kind: missing_ensures_scaffold)
    ensures: SafeFixNotApplied(kind: temporal_guard_scaffold)
}

rule AutofixWritesUpdatedSpecs {
    when: SafeFixApplied(kind)

    ensures: FileWritten(path: "<input>.allium")
    ensures: LinePrinted(message: "<path>: autofixed")
}

rule AutofixDryRunDoesNotWriteChanges {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: command_args includes "--autofix"
    requires: command_args includes "--dryrun"

    ensures: LinePrinted(message: "<path>: would autofix")
    ensures: FileUnchanged(path: "<input>.allium")
}

rule WorkspaceCheckCommandDelegatesToChecker {
    when: WorkspaceCommandInvoked(name: "npm run check -- <inputs>")

    ensures: CheckCommandInvokedWithInputs(inputs)
}

rule WatchModeReevaluatesInputsOnFileChanges {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--watch"

    ensures: CheckRunRepeatedOnInputChange()
}

rule ChangedFlagChecksModifiedAlliumFiles {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--changed"

    ensures: ResolveAlliumFilesFromGitStatus()
}

rule MinSeverityFiltersReportedFindings {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--min-severity warning"

    ensures: FindingsWithSeverity(info) are_filtered_out
}

rule IgnoreCodeFiltersMatchingFindings {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--ignore-code"

    ensures: FindingsWithCode(code) are_filtered_out
}

rule StatsOptionPrintsCountsByCode {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--stats"

    ensures: FindingCountsPrintedGroupedByCode()
}

rule FailOnThresholdControlsBlockingSeverity {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--fail-on error"

    ensures: FindingsWithSeverity(warning) do_not_fail_process
    ensures: FindingsWithSeverity(error) fail_process
}

rule ReportOptionWritesRenderedOutputToPath {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--report"

    ensures: ReportFileWritten(path: options.report_path)
}

rule FixInteractivePromptsBeforeApplyingEachSafeFix {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--autofix"
    requires: options includes "--fix-interactive"

    ensures: SafeFixPromptPrintedPerFix()
    ensures: SafeFixAppliedOnlyWhenAccepted()
}

rule CacheOptionStoresAndReusesFindingsForUnchangedFiles {
    when: CheckCommandInvokedWithOptions(options)
    requires: options includes "--cache"

    ensures: CacheFileWritten(path: ".allium-check-cache.json")
    ensures: UnchangedFilesReuseCachedFindings()
}

rule ConfigFileCanProvideCheckDefaults {
    when: CheckCommandInvokedWithOptions(options)
    requires: FileExists(path: "allium-config-file")
    requires: options excludes "--no-config"

    ensures: ConfigDefaultsLoaded(section: check)
}

rule CheckCanUseProjectSpecPathsFromConfig {
    when: CheckCommandInvokedWithoutInputs()
    requires: FileExists(path: "allium-config-file")
    requires: command_args excludes "--no-config"
    requires: ConfigContainsProjectSpecPaths()

    ensures: CheckCommandUsesConfiguredProjectSpecPaths()
}

rule SpecDriftGateRunsInPreCommitWorkflow {
    when: PreCommitWorkflowInvoked()

    ensures: CommandInvoked(name: "npm run drift:check")
    ensures: CommitBlockedWhenDriftDetected()
}

rule ReleasedCliPackageExposesCheckCommand {
    when: CliPackageInstalledFromReleaseNpmArtifact()

    ensures: CommandAvailable(name: "allium-check")
}

rule StandaloneCheckerMatchesExtensionRuleSet {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs includes spec_file_with_known_informational_findings

    ensures: FindingObserved(code: "allium.field.unused", severity: info)
    ensures: FindingObserved(code: "allium.rule.unreachableTrigger", severity: info)
}

rule CrossModuleReferenceSuppressesUnusedWarning {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs resolve to multiple files
    requires: file_a declares entity_or_value
    requires: file_b references entity_or_value via qualified name (e.g. alias/Name)
    requires: file_b has use declaration mapping alias to file_a

    ensures: FindingNotObserved(code: "allium.entity.unused", entity: entity_or_value)
    ensures: FindingNotObserved(code: "allium.definition.unused", definition: entity_or_value)
}

rule UnresolvedUsePathWarnsInMultiFileMode {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: file contains use declaration with path
    requires: path does not resolve to a file in the check set

    ensures: FindingObserved(code: "allium.use.unresolvedPath", severity: warning)
    ensures: FindingMessage includes path
}

rule QualifiedTriggerCallIsValidTriggerForm {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: rule when clause is qualified trigger call (e.g. alias/Trigger(params))

    ensures: FindingNotObserved(code: "allium.rule.invalidTrigger")
}

rule CrossModuleTriggerEmissionSatisfiesSubscription {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs resolve to multiple files
    requires: file_a provides or emits trigger
    requires: file_b listens for trigger, qualified via use alias mapping to file_a or unqualified
    requires: file_b has use declaration mapping alias to file_a

    ensures: FindingNotObserved(code: "allium.rule.unreachableTrigger", trigger: trigger)
}

rule QualifiedTriggerUnreachableWhenAliasedModuleLacksIt {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs resolve to multiple files
    requires: file_b listens for trigger qualified via use alias mapping to file_a
    requires: file_a neither provides nor emits trigger

    ensures: FindingObserved(code: "allium.rule.unreachableTrigger", severity: info)
    ensures: FindingMessage names the imported module alias
}

rule QualifiedTriggerOutsideCheckSetNotFlagged {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: file listens for trigger qualified via use alias
    requires: alias target does not resolve to a file in the check set

    ensures: FindingNotObserved(code: "allium.rule.unreachableTrigger", trigger: trigger)
}

rule AmbiguousUnqualifiedNameReferenceWarns {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs resolve to multiple files
    requires: two or more distinct imported files declare name
    requires: importing file references name unqualified
    requires: importing file does not declare name locally

    ensures: FindingObserved(code: "allium.use.ambiguousReference", severity: warning)
    ensures: FindingMessage names the candidate import aliases
    ensures: FindingMessage suggests a qualified name
    ensures: at most one finding per ambiguous name, at its first reference site
}

rule AmbiguousUnqualifiedTriggerSubscriptionWarns {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: inputs resolve to multiple files
    requires: two or more distinct imported files provide or emit trigger
    requires: importing file listens for trigger unqualified
    requires: importing file neither provides nor emits trigger locally

    ensures: FindingObserved(code: "allium.use.ambiguousReference", severity: warning)
    ensures: FindingMessage names the candidate import aliases
    ensures: FindingMessage suggests a qualified name
}

rule AmbiguityResolvedByQualificationOrShadowing {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: reference is qualified via use alias, or the importing file declares the name locally, or all matching use aliases target the same file

    ensures: FindingNotObserved(code: "allium.use.ambiguousReference")
}

rule DeferredWithoutLocationHintWarns {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: file contains deferred declaration
    requires: deferred line excludes quoted path, URL, and "-- see:" comment

    ensures: FindingObserved(code: "allium.deferred.missingLocationHint", severity: warning)
}

rule DeferredWithLocationHintSuppressesWarning {
    when: CheckCommandInvokedWithInputs(inputs)
    requires: file contains deferred_declaration
    requires: deferred_declaration line includes quoted path, URL, or "-- see:" comment

    ensures: FindingNotObserved(code: "allium.deferred.missingLocationHint", declaration: deferred_declaration)
}
