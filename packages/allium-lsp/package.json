{
  "name": "allium-lsp",
  "version": "3.4.2",
  "description": "Language Server Protocol server for the Allium language.",
  "license": "MIT",
  "keywords": ["allium", "lsp", "language-server", "specification"],
  "homepage": "https://github.com/juxt/allium-tools/tree/main/packages/allium-lsp#readme",
  "bugs": "https://github.com/juxt/allium-tools/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juxt/allium-tools.git",
    "directory": "packages/allium-lsp"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "allium-lsp": "./dist/bin.js"
  },
  "files": ["dist/**", "README.md", "package.json", "LICENSE"],
  "scripts": {
    "build": "esbuild src/bin.ts --bundle --platform=node --target=node20 --external:allium-parser-wasm --outfile=dist/bin.js --define:require.main=undefined && chmod +x dist/bin.js && cp ../../packages/allium-parser-wasm/allium_wasm.js ../../packages/allium-parser-wasm/allium_wasm_bg.wasm dist/",
    "lint": "tsc --noEmit -p ./tsconfig.json",
    "test": "npm run build && node ../../scripts/run-node-tests.mjs ./test"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3"
  }
}
